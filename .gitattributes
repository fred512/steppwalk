# Normaliza fim de linha — evita quebra do gradlew no CI (Linux)
* text=auto eol=lf

# Scripts shell SEMPRE com LF (gradlew roda no Linux do CI)
gradlew text eol=lf
*.sh text eol=lf

# Scripts/arquivos Windows com CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binários — nunca normalizar
*.jar binary
*.png binary
*.jpg binary
*.ico binary
*.keystore binary
*.webp binary
